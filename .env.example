# ============================================================================
# ADJUTOR API CONFIGURATION
# ============================================================================
# This file serves as a template for local environment variables.
# Copy this to .env and fill in your actual values (DO NOT COMMIT .env)
# ============================================================================

# Your Adjutor API Key from app.adjutor.io
# Format: sk_live_* (production) or sk_test_* (test environment)
# Get yours: https://app.adjutor.io/dashboard/keys
# NEVER commit your real API key to version control!
ADJUTOR_API_KEY=sk_live_eIVIYwPZJe7npIHAcEGRwqAWInRtuc8kMpjkAreN

# Adjutor API Base URL
# Production: https://adjutor.lendsqr.com/v2
# Do NOT change unless instructed by Lendsqr support
BASE_URL=https://adjutor.lendsqr.com/v2

# Currency Code for all transactions
# NGN = Nigerian Naira (required for Nigeria-based tests)
# All pricing in test data is based on NGN
CURRENCY=NGN

# ============================================================================
# IMPLEMENTATION NOTES
# ============================================================================
# - Test data in helpers/testData.js uses official Lendsqr test values
# - Response validation in helpers/responseValidators.js checks all responses
# - Constants in config/constants.js define all pricing (₦10, ₦25, ₦30, etc)
# - Logging config in config/logger.js saves logs to logs/ directory
# - All 4 test modules (Karma, Ecosystem, BVN, Bank Account) ready to run
#
# Performance Expectations:
# - Response threshold: 1500ms (warning if slower)
# - Acceptable range: 200-500ms per call
# - Excellent: < 200ms per call
# ============================================================================